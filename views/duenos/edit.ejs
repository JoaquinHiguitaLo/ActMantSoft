<div class="container mt-4">
    <h2>Editar Dueño</h2>

    <% if (error) { %>
        <div class="alert alert-danger">
            <%= error %>
        </div>
    <% } %>

    <form action="/duenos/edit/<%= dueno.id %>" method="POST" class="card p-4 shadow">

        <div class="mb-3">
            <label>Cédula</label>
            <input type="text" name="cedula" class="form-control" value="<%= dueno.cedula %>" required>
        </div>

        <div class="mb-3">
            <label>Nombre</label>
            <input type="text" name="nombre" class="form-control" value="<%= dueno.nombre %>" required>
        </div>

        <div class="mb-3">
            <label>Celular</label>
            <input type="text" name="celular" class="form-control" value="<%= dueno.celular %>" required>
        </div>

        <div class="mb-3">
            <label>Dirección</label>
            <input type="text" name="direccion" class="form-control" value="<%= dueno.direccion %>" required>
        </div>

        <div class="mb-3">
            <label>Correo</label>
            <input type="email" name="correo" class="form-control" value="<%= dueno.correo || '' %>">
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary">Guardar cambios</button>
            <a href="/duenos" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>