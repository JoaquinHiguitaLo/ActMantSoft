<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Lista de Mascotas</h2>
        <a href="/mascotas/create" class="btn btn-primary">Nueva Mascota</a>
    </div>

    <div class="card p-4 shadow">
        <% if (mascotas.length === 0) { %>
            <p>No hay mascotas registradas.</p>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Raza</th>
                            <th>Color</th>
                            <th>Sexo</th>
                            <th>Edad</th>
                            <th>Dueño</th>
                            <th>Cédula</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% mascotas.forEach(m => { %>
                            <tr>
                                <td><%= m.nombreMasc %></td>
                                <td><%= m.raza %></td>
                                <td><%= m.color %></td>
                                <td><%= m.sexo %></td>
                                <td><%= m.edad %></td>
                                <td><%= m.nombreDueno %></td>
                                <td><%= m.cedula %></td>
                                <td class="d-flex gap-2">
                                    <a href="/mascotas/edit/<%= m.id %>" class="btn btn-sm btn-outline-primary">Editar</a>

                                    <form action="/mascotas/delete/<%= m.id %>" method="POST" onsubmit="return confirm('¿Eliminar esta mascota?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>