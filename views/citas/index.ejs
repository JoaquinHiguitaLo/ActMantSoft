<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Panel de Citas</h1>
    <a href="/citas/create" class="btn btn-primary">Nueva Cita</a>
</div>

<div class="row">
    <% if (citas.length === 0) { %>
        <div class="col-12 text-center py-5">
            <p class="text-muted">No hay citas programadas.</p>
        </div>
    <% } else { %>
        <% citas.forEach(app => { %>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title text-primary">
                                <%= app.mascota_nombre %>
                            </h5>
                            <span class="badge bg-soft-primary text-primary" style="background-color: #e0e0ff;">
                                <%= app.estado %>
                            </span>
                        </div>

                        <p class="card-text mb-1">
                            <strong>Dueño:</strong> <%= app.dueno_nombre %>
                        </p>

                        <p class="card-text mb-1">
                            <strong>Servicio:</strong> <%= app.servicio %>
                        </p>

                        <p class="card-text mb-3">
                            <strong>Fecha:</strong> <%= app.fecha %>
                        </p>

                        <% if (app.peso || app.temperatura || app.diagnostico) { %>
                            <hr>
                            <p class="card-text mb-1">
                                <strong>Peso:</strong> <%= app.peso || 'N/A' %>
                            </p>
                            <p class="card-text mb-1">
                                <strong>Temperatura:</strong> <%= app.temperatura || 'N/A' %>
                            </p>
                            <p class="card-text mb-3">
                                <strong>Diagnóstico:</strong> <%= app.diagnostico || 'N/A' %>
                            </p>
                        <% } %>

                        <form action="/citas/delete/<%= app.id %>" method="POST"
                              onsubmit="return confirm('¿Eliminar esta cita?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                        </form>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>