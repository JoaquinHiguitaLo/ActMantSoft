<div class="container mt-4" style="max-width: 700px;">
    <h2 class="mb-4">Editar Evolución Médica</h2>

    <% if (errores && errores.length > 0) { %>
        <div class="alert alert-danger">
            <ul class="mb-0">
                <% errores.forEach(error => { %>
                    <li><%= error %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <div class="card p-4 shadow">
        <p><strong>Mascota:</strong> <%= cita.mascota_nombre %></p>
        <p><strong>Dueño:</strong> <%= cita.dueno_nombre %></p>
        <p><strong>Servicio:</strong> <%= cita.servicio %></p>
        <p><strong>Fecha:</strong> <%= cita.fecha %></p>

        <hr>

        <form action="/citas/edit-medical/<%= cita.id %>" method="POST">
            <div class="mb-3">
                <label>Peso (kg)</label>
                <input type="number" step="0.01" name="peso" class="form-control" value="<%= cita.peso || '' %>" required>
            </div>

            <div class="mb-3">
                <label>Temperatura (°C)</label>
                <input type="number" step="0.1" name="temperatura" class="form-control" value="<%= cita.temperatura || '' %>" required>
            </div>

            <div class="mb-3">
                <label>Diagnóstico</label>
                <textarea name="diagnostico" class="form-control" rows="4" required><%= cita.diagnostico || '' %></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Guardar evolución médica</button>
                <a href="/citas" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>