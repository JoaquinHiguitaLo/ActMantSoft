<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">Historial Clínico</h1>
        <a href="/citas" class="btn btn-secondary">Volver a Citas</a>
    </div>

    <% if (!mascota) { %>
        <div class="card p-4 shadow">
            <p class="text-muted mb-0">No hay historial clínico registrado para esta mascota.</p>
        </div>
    <% } else { %>

        <div class="card p-4 shadow mb-4">
            <h4 class="mb-3 text-primary"><%= mascota.mascota_nombre %></h4>
            <div class="row">
                <div class="col-md-4">
                    <p><strong>Dueño:</strong> <%= mascota.dueno_nombre %></p>
                    <p><strong>Raza:</strong> <%= mascota.raza %></p>
                </div>
                <div class="col-md-4">
                    <p><strong>Color:</strong> <%= mascota.color %></p>
                    <p><strong>Sexo:</strong> <%= mascota.sexo %></p>
                </div>
                <div class="col-md-4">
                    <p><strong>Edad:</strong> <%= mascota.edad %></p>
                    <p><strong>Total de visitas:</strong> <%= historial.length %></p>
                </div>
            </div>
        </div>

        <div class="timeline">
            <% historial.forEach((cita, index) => { %>
                <div class="card p-4 shadow mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Registro clinico #<%= index + 1 %></h5>
                        <span class="badge bg-primary"><%= cita.fecha %></span>
                    </div>

                    <p><strong>Servicio:</strong> <%= cita.servicio %></p>
                    <p><strong>Estado:</strong> <%= cita.estado %></p>

                 
                <% if (cita.peso || cita.temperatura || cita.diagnostico || cita.medicina_recetada) { %>
                    <hr>
                    <h6 class="text-secondary">Evolución Médica</h6>
                    <p><strong>Peso:</strong> <%= cita.peso || 'No registrado' %></p>
                    <p><strong>Temperatura:</strong> <%= cita.temperatura || 'No registrada' %></p>
                    <p><strong>Diagnóstico:</strong> <%= cita.diagnostico || 'No registrado' %></p>
                    <p><strong>Medicina recetada:</strong> <%= cita.medicina_recetada || 'No recetada' %></p>
                <% } %>
                </div>
            <% }) %>
        </div>

    <% } %>
</div>