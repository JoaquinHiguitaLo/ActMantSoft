<div class="container mt-4">
    <h2>Nueva Cita</h2>

    <% if (errores && errores.length > 0) { %>
        <div class="alert alert-danger">
            <ul class="mb-0">
                <% errores.forEach(error => { %>
                    <li><%= error %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <form action="/citas/create" method="POST" class="card p-4 shadow">

        <div class="mb-3">
            <label>Mascota</label>
            <select name="mascota_id" class="form-control" required>
                <option value="">Seleccione una mascota</option>
                <% mascotas.forEach(m => { %>
                    <option value="<%= m.id %>" <%= oldData.mascota_id == m.id ? 'selected' : '' %>>
                        <%= m.nombreMasc %> - Dueño: <%= m.dueno_nombre %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="mb-3">
            <label>Servicio</label>
            <select name="servicio" id="servicio" class="form-control" required>
                <option value="">Seleccione un servicio</option>
                <option value="Consulta médica" <%= oldData.servicio === 'Consulta médica' ? 'selected' : '' %>>Consulta médica</option>
                <option value="Vacunación" <%= oldData.servicio === 'Vacunación' ? 'selected' : '' %>>Vacunación</option>
                <option value="Baño" <%= oldData.servicio === 'Baño' ? 'selected' : '' %>>Baño</option>
                <option value="Peluquería" <%= oldData.servicio === 'Peluquería' ? 'selected' : '' %>>Peluquería</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Fecha</label>
            <input type="date" name="fecha" class="form-control" value="<%= oldData.fecha || '' %>" required>
        </div>

        <div id="camposMedicos" class="border rounded p-3 mt-3">
            <h5 class="mb-3">Evolución médica</h5>

            <div class="mb-3">
                <label>Peso (kg)</label>
                <input type="number" step="0.01" name="peso" class="form-control" value="<%= oldData.peso || '' %>">
            </div>

            <div class="mb-3">
                <label>Temperatura (°C)</label>
                <input type="number" step="0.1" name="temperatura" class="form-control" value="<%= oldData.temperatura || '' %>">
            </div>

            <div class="mb-3">
                <label>Diagnóstico</label>
                <textarea name="diagnostico" class="form-control" rows="3"><%= oldData.diagnostico || '' %></textarea>
            </div>
        </div>

        <button class="btn btn-primary mt-3">Guardar</button>
    </form>
</div>

<script>
    const servicio = document.getElementById('servicio');
    const camposMedicos = document.getElementById('camposMedicos');

    function toggleCamposMedicos() {
        if (servicio.value === 'Consulta médica') {
            camposMedicos.style.display = 'block';
        } else {
            camposMedicos.style.display = 'none';
        }
    }

    servicio.addEventListener('change', toggleCamposMedicos);
    toggleCamposMedicos();
</script>